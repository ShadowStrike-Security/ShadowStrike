;
; PhantomSensor.inf
;
; ShadowStrike PhantomSensor - NGAV File System Minifilter Driver
;
; Copyright (c) ShadowStrike Security. All rights reserved.
;
; This INF installs PhantomSensor as a file system minifilter driver.
; Compatible with Windows 10 version 1803+ / Windows 11.
;
; Architecture: x64 and ARM64.
;

[Version]
Signature   = "$WINDOWS NT$"
Class       = "AntiVirus"
ClassGuid   = {b1d1a169-c54f-4379-81db-bee7d88d7454}
Provider    = %ManufacturerName%
CatalogFile = PhantomSensor.cat
DriverVer = 03/19/2026,18.30.36.165
PnpLockdown = 1

; ---------------------------------------------------------------------------
; Destination: system32\drivers (DIRID 12)
; ---------------------------------------------------------------------------

[DestinationDirs]
DefaultDestDir          = 12
PhantomSensor.CopyFiles = 12

[SourceDisksNames]
1 = %DiskName%

[SourceDisksFiles]
PhantomSensor.sys = 1

; ---------------------------------------------------------------------------
; Install Sections (x64)
; ---------------------------------------------------------------------------

[DefaultInstall.NTAMD64]
OptionDesc = %ServiceDescription%
CopyFiles  = PhantomSensor.CopyFiles

[DefaultInstall.NTAMD64.Services]
AddService = %ServiceName%,,PhantomSensor.Service

; ---------------------------------------------------------------------------
; Install Sections (ARM64)
; ---------------------------------------------------------------------------

[DefaultInstall.NTARM64]
OptionDesc = %ServiceDescription%
CopyFiles  = PhantomSensor.CopyFiles

[DefaultInstall.NTARM64.Services]
AddService = %ServiceName%,,PhantomSensor.Service

; ---------------------------------------------------------------------------
; Copy Files
; ---------------------------------------------------------------------------

[PhantomSensor.CopyFiles]
PhantomSensor.sys

; ---------------------------------------------------------------------------
; Uninstall Sections (x64)
; ---------------------------------------------------------------------------

[DefaultUninstall.NTAMD64]
LegacyUninstall = 1
DelFiles        = PhantomSensor.CopyFiles

[DefaultUninstall.NTAMD64.Services]
DelService = %ServiceName%,0x200

; ---------------------------------------------------------------------------
; Uninstall Sections (ARM64)
; ---------------------------------------------------------------------------

[DefaultUninstall.NTARM64]
LegacyUninstall = 1
DelFiles        = PhantomSensor.CopyFiles

[DefaultUninstall.NTARM64.Services]
DelService = %ServiceName%,0x200

; ---------------------------------------------------------------------------
; Service Configuration
; ---------------------------------------------------------------------------

[PhantomSensor.Service]
DisplayName    = %ServiceDisplayName%
Description    = %ServiceDescription%
ServiceType    = 2               ; SERVICE_FILE_SYSTEM_DRIVER
StartType      = 3               ; SERVICE_DEMAND_START (safe for testing; switch to 1 after stability validation)
ErrorControl   = 1               ; SERVICE_ERROR_NORMAL
ServiceBinary  = %12%\PhantomSensor.sys
LoadOrderGroup = FSFilter Anti-Virus
AddReg         = PhantomSensor.AddRegistry

; ---------------------------------------------------------------------------
; Minifilter Instance Registration
;
; The altitude places PhantomSensor in the FSFilter Anti-Virus load order group.
; NOTE: For production WHQL submission, request a dedicated altitude from
; Microsoft via the minifilter altitude allocation process at:
;   https://learn.microsoft.com/windows-hardware/drivers/ifs/minifilter-altitude-request
; ---------------------------------------------------------------------------

[PhantomSensor.AddRegistry]
HKR,"Parameters\Instances","DefaultInstance",0x00000000,%DefaultInstance%
HKR,"Parameters\Instances\%DefaultInstance%","Altitude",0x00000000,%Altitude%
HKR,"Parameters\Instances\%DefaultInstance%","Flags",0x00010001,%Flags%

; ---------------------------------------------------------------------------
; Strings
; ---------------------------------------------------------------------------

[Strings]
ManufacturerName   = "ShadowStrike Security"
ServiceName        = "PhantomSensor"
ServiceDisplayName = "ShadowStrike PhantomSensor"
ServiceDescription = "ShadowStrike Next-Generation AntiVirus kernel sensor for real-time threat detection, ransomware protection, and endpoint security"
DiskName           = "ShadowStrike PhantomSensor Installation Disk"
DefaultInstance    = "PhantomSensor Instance"
Altitude           = "385210"
Flags              = 0x0
